# Real Estate Price Prediction - Environment Configuration

# =============================================================================
# KAFKA Configuration
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_RAW_TOPIC=real_estate_raw
KAFKA_CLEAN_TOPIC=real_estate_features
KAFKA_GROUP_ID=real_estate_training_pipeline

# =============================================================================
# MongoDB Configuration
# =============================================================================
MONGO_URI=mongodb://mongodb:27017/
MONGO_DB=real_estate_db
MONGO_FEATURE_COLLECTION=training_features

# =============================================================================
# Model Configuration
# =============================================================================
MODEL_PATH=artifacts/price_model_current.joblib
METRICS_PATH=artifacts/price_model_metrics.json

# =============================================================================
# API Configuration
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=*,localhost:3000

# =============================================================================
# Prediction Service Configuration
# =============================================================================
PREDICTOR_HOST=0.0.0.0
PREDICTOR_PORT=8002

# =============================================================================
# Metrics Configuration
# =============================================================================
PROMETHEUS_METRICS_PORT=8000
PROMETHEUS_INTERVAL=15

# =============================================================================
# Frontend Configuration
# =============================================================================
VITE_API_URL=http://localhost:8000
VITE_APP_NAME=RealEstateAI
VITE_APP_VERSION=1.0.0

# =============================================================================
# Environment
# =============================================================================
ENVIRONMENT=development
LOG_LEVEL=INFO
DEBUG=false
